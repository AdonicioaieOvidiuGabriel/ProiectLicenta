# LICENTACONNECT Backend Configuration
# Copy this file to .env and fill in your actual values

# Azure OpenAI Configuration (Primary AI Provider)
# Get these values from your Azure OpenAI deployment:
# - Endpoint: https://[resource-name].openai.azure.com/
# - API Key: Available from Azure portal > Keys and Endpoint
# - Deployment name: The name of your deployed gpt-4o model
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://licentaconnect-ai-usm.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-04-01-preview

# AI Provider Selection
# Options: 'azure' (recommended), 'gemini' (Google Generative AI), or 'groq' (legacy/unsupported)
AI_PROVIDER=azure

# Real email delivery via SMTP (recommended for actual sending)
# Example for Gmail requires an App Password, not your normal login password.
# Set these to real values if you want actual delivery to the professor.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# When true, /api/send-email routes delivery to the studentEmail instead of profesorEmail (for testing only).
EMAIL_TEST_MODE=false

# SendGrid (preferred transactional provider)
# You can paste your SendGrid API key here. The server will use SendGrid SMTP relay
# automatically when SENDGRID_API_KEY is set. Optionally set SENDGRID_FROM to control
# the default "from" address used for sent messages.
SENDGRID_API_KEY=
SENDGRID_FROM=
# Optional overrides for SendGrid SMTP connection (usually not needed):
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_SMTP_SECURE=false
SENDGRID_SMTP_USER=apikey

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend CORS Origin
FRONTEND_URL=http://localhost:5173

# MySQL topics storage
# If these are set, the backend will load topics from MySQL first.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=licentaconnect
MYSQL_CONNECTION_LIMIT=10
MYSQL_CHARSET=utf8mb4

# One-time import after creating the schema:
# node scripts/import-topics-to-mysql.js
